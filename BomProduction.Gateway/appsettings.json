{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "SuperLlaveSecretaUltraLargaParaElBOM2026!#%"
  },
  "ReverseProxy": {
    "Routes": {
      "authRoute": {
        "ClusterId": "queryCluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
        // Nota: NO le ponemos AuthorizationPolicy, porque el Login DEBE ser público
      },
      "queryRoute": {
        "ClusterId": "queryCluster",
        "Match": {
          "Path": "/api/query/{**catch-all}"
        },
        "AuthorizationPolicy": "RequireJwt" // <-- CANDADO PUESTO
      },
      "engineRoute": {
        "ClusterId": "engineCluster",
        "Match": {
          "Path": "/api/bom/{**catch-all}"
        },
        "AuthorizationPolicy": "RequireJwt" // <-- CANDADO PUESTO
      }
    },
    "Clusters": {
      "queryCluster": {
        "Destinations": {
          "destination1": { "Address": "http://bom_query_api:8080" }
        }
      },
      "engineCluster": {
        "Destinations": {
          "destination1": { "Address": "http://bom_engine_api:8080" }
        }
      }
    }
  }
}